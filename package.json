{
  "name": "agentis-multi",
  "version": "0.2.0",
  "description": "A TypeScript framework for building sophisticated multi-agent systems",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "jest",
    "chat": "ts-node src/tests/agent-chat.ts",
    "market-team": "ts-node src/examples/market-team.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "framework",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/agentis"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "@tavily/core": "^0.3.1",
    "dotenv": "^16.4.7",
    "immutable": "^5.0.3",
    "openai": "^4.85.1",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.17.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
